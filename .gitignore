# ============================================================
# Intelligent Coding Assistant - Git Ignore Rules
# ============================================================

# ----------------------------------------------------------
# Environment & Secrets
# ----------------------------------------------------------
.env
.env.local
.env.*.local

# ----------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----------------------------------------------------------
# Backend (Java / Spring Boot)
# ----------------------------------------------------------
backend/target/
backend/*.jar
backend/*.war
backend/.mvn/wrapper/maven-wrapper.jar

# ----------------------------------------------------------
# Frontend (Node.js / Vue)
# ----------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.temp/

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
docker/mysql/data/
docker/neo4j/data/

# ----------------------------------------------------------
# OS Generated Files
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.tmp
*.bak
*.orig