<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coding.assistant.mapper.LearningNodeMapper">

    <resultMap id="BaseResultMap" type="com.coding.assistant.entity.LearningNode">
        <id property="id" column="id"/>
        <result property="pathId" column="path_id"/>
        <result property="knowledgeId" column="knowledge_id"/>
        <result property="nodeOrder" column="node_order"/>
        <result property="status" column="status"/>
        <result property="resourceUrls" column="resource_urls"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByPathId" resultMap="BaseResultMap">
        SELECT * FROM learning_node WHERE path_id = #{pathId} ORDER BY node_order ASC
    </select>

    <delete id="deleteByPathId">
        DELETE FROM learning_node WHERE path_id = #{pathId}
    </delete>

</mapper>