# ============================================================
# Intelligent Coding Assistant - Environment Template
# Copy this file to .env and fill in real values.
# ============================================================

# Runtime profile: dev / test / prod
SPRING_PROFILES_ACTIVE=prod

# ----------------------------------------------------------
# MySQL
# ----------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=coding_assistant
MYSQL_USER=root
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_DATABASE=coding_assistant

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------
# Neo4j
# ----------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# ----------------------------------------------------------
# JWT
# ----------------------------------------------------------
JWT_SECRET=change_me_to_a_random_32_plus_char_secret
JWT_EXPIRATION=86400000

# ----------------------------------------------------------
# LLM
# ----------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=change_me_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CHATGLM_API_KEY=
CHATGLM_BASE_URL=
CHATGLM_MODEL=chatglm3-turbo
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-turbo

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
SERVER_PORT=8080
UPLOAD_DIR=./uploads
APP_LOG_LEVEL=info
