# ============================================================
# Intelligent Coding Assistant - Environment Template
# Copy this file to .env and fill in real values.
# Backend configuration layering:
# - application.yml (base) + application-{dev|test|prod}.yml (profile override)
# - backend will auto-import `.env` (repo root) when present
# ============================================================

# Runtime profile: dev / test / prod
SPRING_PROFILES_ACTIVE=dev

# ----------------------------------------------------------
# MySQL
# ----------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=coding_assistant
MYSQL_USER=root
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_DATABASE=coding_assistant

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------
# Neo4j
# ----------------------------------------------------------
NEO4J_URI=bolt://localhost:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password
NEO4J_HTTP_HOST_PORT=17474
NEO4J_BOLT_HOST_PORT=17687

# ----------------------------------------------------------
# JWT
# ----------------------------------------------------------
JWT_SECRET=change_me_to_a_random_32_plus_char_secret
JWT_EXPIRATION=86400000

# ----------------------------------------------------------
# LLM
# ----------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=change_me_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CHATGLM_API_KEY=
CHATGLM_BASE_URL=
CHATGLM_MODEL=chatglm3-turbo
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-turbo

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
SERVER_PORT=8080
UPLOAD_DIR=./uploads
APP_LOG_LEVEL=info

# ----------------------------------------------------------
# Vector Search (Elasticsearch)
# ----------------------------------------------------------
VECTOR_SEARCH_URIS=http://localhost:19200
VECTOR_SEARCH_ENABLED=true
VECTOR_SEARCH_INDEX=knowledge_document_vector
VECTOR_SEARCH_CHUNK_INDEX=knowledge_chunk_vector
VECTOR_SEARCH_QUERY_LOG_ENABLED=true
VECTOR_SEARCH_QUERY_LOG_INDEX=query_log_index
VECTOR_SEARCH_RETRIEVAL_LOG_INDEX=retrieval_log_index
VECTOR_SEARCH_TIMEOUT_MS=3000
VECTOR_SEARCH_NUM_CANDIDATES=50
